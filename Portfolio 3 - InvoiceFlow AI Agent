    {
      "parameters": {
        "jsCode": "const output = [];\n\nfor (let i = 0; i < items.length; i++) {\n  const binaryData = items[i].binary?.data;\n\n  if (!binaryData) {\n    output.push({\n      json: {\n        error: \"No binary data found\",\n        fileName: items[i].json.name || \"empty\",\n        mimeType: \"empty\",\n        image_base64: \"empty\",\n        image_data_url: \"empty\"\n      }\n    });\n    continue;\n  }\n\n  const buffer = await this.helpers.getBinaryDataBuffer(i, 'data');\n  const mimeType = binaryData.mimeType || \"image/jpeg\";\n  const base64 = buffer.toString('base64');\n\n  output.push({\n    json: {\n      ...items[i].json,\n      fileName: binaryData.fileName || items[i].json.name || \"empty\",\n      mimeType,\n      image_base64: base64,\n      image_data_url: `data:${mimeType};base64,${base64}`\n    }\n  });\n}\n\nreturn output;"
      },
