        "jsonBody": "={\n  \"model\": \"google/gemini-2.5-flash\",\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": [\n        {\n          \"type\": \"text\",\n          \"text\": \"You are an invoice data extraction assistant. Analyze the invoice image and extract only these fields: seller_name, customer_name, number_of_items, Invoice No, total_cost, date_of_issue. Rules: Extract only clearly visible information. Do not guess or invent missing values. If any field is missing or unclear, write \\\"empty\\\". number_of_items means the number of invoice line items listed in the items table, not the total quantity. total_cost means the final total amount due, gross total, amount due, or grand total. Return exactly these keys: seller_name,  customer_name, number_of_items, total_cost, Invoice No, date_of_issue. Do not use markdown.\"\n        },\n        {\n          \"type\": \"image_url\",\n          \"image_url\": {\n            \"url\": \"{{$json.image_data_url}}\"\n          }\n        }\n      ]\n    }\n  ],\n  \"temperature\": 0,\n  \"max_tokens\": 500\n}",
